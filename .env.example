# Database (Neon for production, local Postgres or Neon for dev)
DATABASE_URL="postgresql://user:password@host:5432/ultrakey_invoice?sslmode=require"

# JWT Authentication (use a strong random secret in production)
JWT_SECRET="change-me-in-production-use-a-real-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP (Gmail: use App Password from https://myaccount.google.com/apppasswords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
